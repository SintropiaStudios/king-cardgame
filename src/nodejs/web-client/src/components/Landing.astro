---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'pt-br' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const base = lang === 'en' ? '/king-cardgame/en' : '/king-cardgame';
---

<section id="landing-hero" class="hero">
  <div class="hero-content">
    <h1>{t('hero.title')}</h1>
    <p class="subtitle">{t('hero.subtitle')}</p>
    
    <div class="cta-group">
      <button id="play-button" class="primary-btn">{t('hero.play')}</button>
      <a href={lang === 'en' ? '/king-cardgame/' : '/king-cardgame/en/'} class="secondary-btn">
        {lang === 'en' ? 'Português' : 'English'}
      </a>
    </div>
  </div>

  <div class="features-grid">
    <div class="feature-card">
      <div class="icon-box">🃏</div>
      <h3>{t('features.multiplayer')}</h3>
      <p class="feature-desc">{t('features.multiplayer.desc')}</p>
      <div class="visual-placeholder card-fan">
        <div class="mini-card"></div>
        <div class="mini-card"></div>
        <div class="mini-card"></div>
      </div>
      <a href={`${base}/rules`} class="learn-more">{t('features.learn_more')} →</a>
    </div>
    
    <div class="feature-card">
      <div class="icon-box">🌐</div>
      <h3>{t('features.polyglot')}</h3>
      <p class="feature-desc">{t('features.polyglot.desc')}</p>
      <div class="visual-placeholder lang-icons">
        <span>λ</span>
        <span>🦀</span>
        <span>C++</span>
        <span>JS</span>
      </div>
      <a href={`${base}/clients`} class="learn-more">{t('features.learn_more')} →</a>
    </div>

    <div class="feature-card">
      <div class="icon-box">🔓</div>
      <h3>{t('features.opensource')}</h3>
      <p class="feature-desc">{t('features.opensource.desc')}</p>
      <div class="visual-placeholder github-visual">
        <svg viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
      </div>
      <a href={t('link.github')} class="learn-more" target="_blank" rel="noopener noreferrer">{t('features.learn_more')} →</a>
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 6rem 2rem;
    text-align: center;
    background: radial-gradient(circle at center, #1e232d 0%, #13151a 100%);
    min-height: 80vh;
    justify-content: center;
  }

  .hero-content {
    max-width: 900px;
    margin-bottom: 4rem;
  }

  h1 {
    font-size: 4.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }

  .subtitle {
    font-size: 1.5rem;
    color: #b0b0b0;
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .primary-btn {
    background: var(--accent);
    color: #13151a;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1.25rem;
    border: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
  }

  .primary-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4);
  }

  .secondary-btn {
    background: rgba(255,255,255,0.05);
    color: white;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.1);
    transition: background 0.2s;
  }

  .secondary-btn:hover {
    background: rgba(255,255,255,0.1);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    width: 100%;
    max-width: 1200px;
  }

  .feature-card {
    background: rgba(255,255,255,0.03);
    padding: 2rem;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.05);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .feature-card:hover {
    border-color: var(--accent);
    background: rgba(255,255,255,0.05);
    transform: translateY(-5px);
  }

  .feature-desc {
    color: #888;
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 1.5rem;
    height: 3rem;
  }

  .learn-more {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    margin-top: auto;
    font-size: 0.9rem;
    transition: opacity 0.2s;
  }

  .learn-more:hover {
    opacity: 0.8;
  }

  .icon-box {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  h3 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--accent);
  }

  .visual-placeholder {
    height: 120px;
    width: 100%;
    background: rgba(255,255,255,0.02);
    border-radius: 12px;
    border: 1px dashed rgba(255,255,255,0.1);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  /* Card Fan Animation */
  .card-fan {
    perspective: 1000px;
  }

  .mini-card {
    width: 40px;
    height: 60px;
    background: white;
    border-radius: 4px;
    position: absolute;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    border: 1px solid #ddd;
    transition: transform 0.5s ease;
  }

  .mini-card:nth-child(1) { transform: rotate(-15deg) translateX(-20px); background: #eee; }
  .mini-card:nth-child(2) { transform: rotate(0deg); z-index: 2; }
  .mini-card:nth-child(3) { transform: rotate(15deg) translateX(20px); background: #eee; }

  .feature-card:hover .mini-card:nth-child(1) { transform: rotate(-30deg) translateX(-35px); }
  .feature-card:hover .mini-card:nth-child(3) { transform: rotate(30deg) translateX(35px); }

  /* Lang Icons Ticker */
  .lang-icons {
    gap: 1rem;
    font-weight: bold;
    color: #555;
    font-size: 1.2rem;
  }

  .lang-icons span {
    transition: color 0.3s;
  }

  .feature-card:hover .lang-icons span {
    color: var(--accent);
  }

  /* GitHub Visual */
  .github-visual {
    color: #444;
    transition: color 0.3s;
  }

  .feature-card:hover .github-visual {
    color: white;
  }

  @media (max-width: 768px) {
    h1 { font-size: 3rem; }
    .subtitle { font-size: 1.2rem; }
    .cta-group { flex-direction: column; }
  }
</style>
