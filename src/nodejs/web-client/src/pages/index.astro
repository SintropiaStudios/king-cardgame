---
// src/pages/index.astro
---
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>King: Open Network Client</title>
        <link href="/cards.css" rel="stylesheet" type="text/css" />
        <link href="/king.css" rel="stylesheet" type="text/css" />
        <style>
            .hero {
                background: #1a1a1a;
                color: white;
                padding: 4rem 2rem;
                text-align: center;
                border-bottom: 4px solid #d4af37;
            }
            .hero h1 { font-size: 3rem; margin-bottom: 1rem; color: #d4af37; }
            .hero p { font-size: 1.25rem; max-width: 800px; margin: 0 auto; color: #ccc; }
            
            #game-container {
                margin: 2rem auto;
                max-width: 1200px;
                background: #004d00;
                padding: 2rem;
                border-radius: 12px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            }
        </style>
    </head>
    <body>
        <section class="hero">
            <h1>The Open King Network</h1>
            <p>
                Experience the ultimate strategic trick-taking card game. 
                Built on an open protocol, played across a polyglot ecosystem. 
                Join the "Aloja" tradition.
            </p>
        </section>

        <main id="game-container">
            <div id="infobox">
                <span id="infocontent"></span>
            </div>

            <!-- Header -->
            <div id="header">
                <button id="console-btn">Console</button>
                <button id="authorize-btn">Authorize Player</button>
                <button id="start-btn">Join/Start Match</button>
                <h2>King Online</h2>
            </div>
            
            <!-- Table's area -->
            <div id="table" class="playingField">
                <div id="name1" class="textBox name">Right</div>
                <div id="score1" class="textBox">&nbsp;</div>
                <div id="name2" class="textBox name">Top</div>
                <div id="score2" class="textBox">&nbsp;</div>
                <div id="name3" class="textBox name">Left</div>
                <div id="score3" class="textBox">&nbsp;</div>
                <div id="tableCards" class="cardArea"></div>
            </div>

            <!-- Main player's area -->
            <div id="player" class="playingField">
                <div class="textBox name">Player</div>
                <div id="score0" class="textBox">&nbsp;</div>
                <div id="playerCards" class="cardArea"></div>
            </div>

            <div id="command-panel">
                <ul id="messages"></ul>
                <form id="command-form">
                    <input id="m" autocomplete="off" placeholder="Enter raw command..." />
                    <button>Send</button>
                </form>
            </div>
        </main>

        <!-- Scripts -->
        <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
        <script is:inline src="https://code.jquery.com/jquery-3.1.1.js"></script>
        <script is:inline src="/jquery.keyframes.js"></script>
        <script is:inline src="/cards.js"></script>
        <script is:inline src="/king.js"></script>

        <script is:inline>
            // Connect to the standalone Node.js Proxy on port 3000
            var socket = io('http://localhost:3000'); 
            var cur_game = null;

            socket.on('response', function(data) {
                $('#messages').append($('<li>').text('RESPONSE: ' + data));
            });

            socket.on('info', function(msg) {
                $('#messages').append($('<li>').text('INFO: ' + msg).addClass('info'));
            });

            $('#command-form').submit(function(e){
                e.preventDefault();
                socket.emit('action', $('#m').val());
                $('#m').val('');
                return false;
            });

            $('#console-btn').on('click', function(evt) {
                var elem = $('#command-panel');
                elem.toggleClass('visible');
            });

            $('#authorize-btn').on('click', function(evt){
                if (cur_game === null) {
                    var name = prompt('Enter name:');
                    var password = prompt('Password:');
                    cur_game = new Game(name);
                    authorize(cur_game, password)
                }
            });

            $('#start-btn').on('click', function(evt){
                if (cur_game !== null && cur_game.channel) {
                    hunt_table(cur_game);
                }
            });

            // Initialize Animations
            var table = $('#tableCards');
            var tempCard = $((new Card('2','C')).createNode()).css('visibility','hidden').appendTo(table);
            var middleTable = { 
                x: table.innerWidth() / 2 - tempCard.width() / 2,
                y: table.innerHeight() / 2 - tempCard.height() / 2
            };

            $.keyframe.define([{
                name: `tableCard${PlayerPosition.BOTTOM}`,
                from: { transform: `translate(${middleTable.x}px, ${table.innerHeight() + 100}px)` },
                to: { transform: `translate(${middleTable.x}px, ${middleTable.y + 50}px)` }
            }, {
                name: `tableCard${PlayerPosition.RIGHT}`,
                from: { transform: `translate(${table.innerWidth() + 100}px, ${middleTable.y}px)` },
                to: { transform: `translate(${middleTable.x + 50}px, ${middleTable.y}px)` }
            }, {
                name: `tableCard${PlayerPosition.TOP}`,
                from: { transform: `translate(${middleTable.x}px, -100px)` },
                to: { transform: `translate(${middleTable.x}px, ${middleTable.y - 50}px)` }
            }, {
                name: `tableCard${PlayerPosition.LEFT}`,
                from: { transform: `translate(-100px, ${middleTable.y}px)` },
                to: { transform: `translate(${middleTable.x - 50}px, ${middleTable.y}px)` }
            }]);

            var hand = $('#playerCards');
            var middle = hand.innerWidth() / 2;
            for (var i=0; i<13; i++) {
                $.keyframe.define([{
                    name: `handCard${i}`,
                    from: { transform: `translateX(${middle}px)` },
                    to: { transform: `translateX(${2*i}em)` }
                }, {
                    name: 'playHandCard',
                    from: { transform: `translate(${2*i}em, 0em)`, opacity: 1, visibility: 'visible' },
                    to: { transform: `translate(${middle}px, -10em)`, opacity: 0, visibility: 'hidden' }
                }]);
            }
        </script>
    </body>
</html>
