---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'pt-br';
const t = useTranslations(lang);

const base = lang === 'en' ? '/king-cardgame/en' : '/king-cardgame';
---

<Layout title={t('clients.title')} lang={lang}>
	<main class="content-page">
		<header class="hero-small">
			<a href={base} class="back-link">← Voltar</a>
			<h1>{t('clients.title')}</h1>
			<p class="subtitle">{t('clients.intro')}</p>
		</header>

		<div class="clients-grid">
			<div class="client-card">
				<div class="tag server">Server</div>
				<h3>Haskell King Server</h3>
				<p>O núcleo autoritário do jogo. Gerencia regras, estado e comunicações via ZMQ.</p>
				<code>src/haskell/king-game</code>
			</div>

			<div class="client-card">
				<div class="tag client">Web</div>
				<h3>Node.js & Astro Client</h3>
				<p>Esta interface web, utilizando Socket.io como gateway para o servidor ZMQ.</p>
				<code>src/nodejs/web-client</code>
			</div>

			<div class="client-card">
				<div class="tag client">Native</div>
				<h3>C++ Vulkan Client</h3>
				<p>Implementação de alto desempenho com renderização Vulkan nativa.</p>
				<code>src/cpp/vulkan-client</code>
			</div>

			<div class="client-card">
				<div class="tag bot">AI</div>
				<h3>Rust Random Bot</h3>
				<p>Um agente automatizado que demonstra como interagir com o protocolo via Rust.</p>
				<code>src/rust/client</code>
			</div>

			<div class="client-card">
				<div class="tag client">Desktop</div>
				<h3>C# MonoGame Client</h3>
				<p>Cliente cross-platform construído com o framework MonoGame.</p>
				<code>src/csharp/client</code>
			</div>

			<div class="client-card">
				<div class="tag server">Reference</div>
				<h3>Python Core</h3>
				<p>A implementação original e de referência. Contém a lógica base e scripts de teste.</p>
				<code>src/python</code>
			</div>
		</div>
	</main>
</Layout>

<style>
	.content-page {
		max-width: 1200px;
		margin: 0 auto;
		padding: 6rem 2rem;
		min-height: 100vh;
		background: radial-gradient(circle at top, #1e232d 0%, #13151a 100%);
	}

	.hero-small {
		margin-bottom: 5rem;
		text-align: center;
	}

	.back-link {
		color: var(--accent);
		text-decoration: none;
		display: inline-block;
		margin-bottom: 2rem;
		font-weight: 600;
		transition: opacity 0.2s;
	}

	.back-link:hover {
		opacity: 0.8;
	}

	h1 {
		font-size: 4rem;
		margin-bottom: 1.5rem;
		background: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.subtitle {
		font-size: 1.4rem;
		color: #b0b0b0;
		max-width: 800px;
		margin: 0 auto;
	}

	.clients-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 2rem;
	}

	.client-card {
		background: rgba(255,255,255,0.03);
		padding: 2.5rem;
		border-radius: 24px;
		border: 1px solid rgba(255,255,255,0.05);
		transition: transform 0.3s ease;
		display: flex;
		flex-direction: column;
	}

	.client-card:hover {
		transform: translateY(-5px);
		border-color: var(--accent);
	}

	.tag {
		align-self: flex-start;
		padding: 0.35rem 0.85rem;
		border-radius: 6px;
		font-size: 0.7rem;
		font-weight: 800;
		text-transform: uppercase;
		margin-bottom: 1.5rem;
		letter-spacing: 0.05em;
	}

	.server { background: #4a148c; color: white; }
	.client { background: #1b5e20; color: white; }
	.bot { background: #b71c1c; color: white; }

	h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		color: white;
	}

	p {
		color: #aaa;
		line-height: 1.7;
		margin-bottom: 2rem;
		flex-grow: 1;
	}

	code {
		background: #000;
		padding: 0.75rem 1rem;
		border-radius: 8px;
		font-size: 0.85rem;
		color: var(--accent);
		border: 1px solid rgba(212, 175, 55, 0.2);
	}

	@media (max-width: 768px) {
		h1 { font-size: 2.5rem; }
		.clients-grid { grid-template-columns: 1fr; }
	}
</style>
